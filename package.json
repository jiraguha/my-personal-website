{
  "name": "sdd-fullstack-v2",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:ui\"",
    "dev:api": "bun run --watch src/api/index.ts",
    "dev:ui": "vite",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:reset": "docker compose -f infra/docker-compose.yml down -v && docker compose -f infra/docker-compose.yml up -d",
    "test": "bun run test:api && bun run test:ui",
    "test:api": "bun test test/api/",
    "test:ui": "playwright test test/ui/",
    "test:e2e": "playwright test test/e2e/",
    "test:all": "bun run test:api && bun run test:ui && bun run test:e2e",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  }
}
